# --- App / Docker ---
APPDATA_DIR=./appdata
MAX_CONCURRENT_JOBS=2

# --- Browser ---
USER_DATA_DIR=playwright-profile
HEADLESS=false
# Use system Google Chrome. Leave blank only if Playwright-managed Chromium is installed.
BROWSER_CHANNEL=chrome
DEFAULT_TIMEOUT_MS=15000
TIMEZONE=America/Vancouver

# --- Yodel Login ---
# Required only if the persistent browser profile is not already logged in.
# Leave both blank to rely on an already-authenticated profile.
YODEL_EMAIL=
YODEL_PASSWORD=

# --- Booking Target & Timing ---
TARGET_DATE=2026-06-18
SCHEDULE=true
START_TIME=07:00
SLOW_POLL_UNTIL=06:59
PREP_MINUTES_BEFORE=30
AUTH_DEADLINE_MINUTES_BEFORE=5
POLL_DEADLINE_SECONDS=120
POLL_MIN_SECONDS=1.4
POLL_MAX_SECONDS=3.6
RUN_MODE=manual

# --- Booking URLs ---
ALL_DAY_PASS_URL=https://yodelportal.com/buntzen-lake
HALF_DAY_PASS_URL=https://yodelportal.com/buntzen-lake

# --- Vehicle Selection ---
VEHICLE_KEYWORD=Tesla

# --- Pass Type Selection ---
CHECK_ALL_DAY=true
CHECK_MORNING=false
CHECK_AFTERNOON=false

# --- Twilio OTP + Alerts ---
# The Yodel account 2FA number should be an SMS-capable Twilio number.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_OTP_NUMBER=+16045551212
TWILIO_ALERTS_ENABLED=true
TWILIO_ALERT_TO_NUMBER=+16045559876
OTP_TIMEOUT_SECONDS=120
OTP_POLL_INTERVAL_SECONDS=3
